<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <solid android:color="#FFFFFF" />
            <stroke android:width="1dp" android:color="#E5E7EB" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <item android:right="310dp"> <!-- Ajustado para simular la línea verde lateral en pantallas estándar -->
        <shape>
            <solid android:color="#1E5631" />
            <corners android:topLeftRadius="16dp" android:bottomLeftRadius="16dp"/>
        </shape>
    </item>
</layer-list>