<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_general">

    <!-- BARRA SUPERIOR (Lactario + Gear) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/top_nav_bar"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:background="@color/surface"
        android:paddingHorizontal="24dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tv_app_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/lactario"
            android:textColor="@color/primary_green"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSimularPremium"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginStart="12dp"
            android:text="Simular Premium"
            android:textSize="10sp"
            android:paddingHorizontal="8dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:cornerRadius="8dp"
            app:backgroundTint="@color/primary_purple"
            app:layout_constraintBottom_toBottomOf="@id/tv_app_title"
            app:layout_constraintStart_toEndOf="@id/tv_app_title"
            app:layout_constraintTop_toTopOf="@id/tv_app_title" />

        <ImageButton
            android:id="@+id/config_top_btn"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_settings"
            app:tint="@color/primary_green"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:contentDescription="@string/configuracion" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#EEEEEE"
            app:layout_constraintBottom_toBottomOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- CONTENEDOR DE FRAGMENTOS (Sin scrollbar visible) -->
    <FrameLayout
        android:id="@+id/nav_host_fragment"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/bottom_navigation"
        app:layout_constraintTop_toBottomOf="@id/top_nav_bar" />

    <!-- NAVEGACIÓN INFERIOR (Estilo personalizado según la imagen) -->
    <LinearLayout
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@color/surface"
        android:elevation="8dp"
        android:orientation="horizontal"
        android:paddingBottom="12dp"
        android:weightSum="4"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Registro -->
        <LinearLayout
            android:id="@+id/btn_nav_registro"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_edit"
                app:tint="@color/primary_green" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Registro"
                android:textColor="@color/primary_green"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Dashboard -->
        <LinearLayout
            android:id="@+id/btn_nav_dashboard"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_dashboard"
                app:tint="@color/text_muted" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dashboard"
                android:textColor="@color/text_muted"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Estadísticas -->
        <LinearLayout
            android:id="@+id/btn_nav_estadisticas"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_analytics"
                app:tint="@color/text_muted" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Estadísticas"
                android:textColor="@color/text_muted"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Ganado -->
        <LinearLayout
            android:id="@+id/btn_nav_ganado"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_cow"
                app:tint="@color/text_muted" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ganado"
                android:textColor="@color/text_muted"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Eliminado sec_registro redundante para limpiar el layout principal -->

</androidx.constraintlayout.widget.ConstraintLayout>
