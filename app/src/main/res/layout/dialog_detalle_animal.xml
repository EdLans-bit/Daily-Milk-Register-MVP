<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvTituloDetalle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Estadísticas del Animal"
        android:textColor="@color/primary_green"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="@color/border_color"
        app:cardBackgroundColor="@color/bg_general">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvLitrosTotales"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Litros totales: 0.0 L"
                android:textColor="@color/text_main"
                android:textSize="16sp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvProduccionMaxima"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Máximo en un día: 0.0 L"
                android:textColor="@color/primary_green"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvProduccionMinima"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mínimo en un día: 0.0 L"
                android:textColor="@color/btn_danger_text"
                android:textSize="14sp"
                android:layout_marginBottom="12dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/border_color"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:id="@+id/tvFechaRegistro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Registrado el: --/--/----"
                android:textColor="@color/text_muted"
                android:textSize="12sp"
                android:textStyle="italic"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
