<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_general">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📊"
                android:textSize="24sp"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Estadísticas"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/primary_green"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:background="@drawable/bg_circle_green"
            android:backgroundTint="@color/bg_badge"
            android:layout_marginBottom="20dp"
            android:padding="4dp">

            <TextView
                android:id="@+id/btn_dia"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="DÍA"
                android:gravity="center"
                android:textStyle="bold"
                android:textColor="@color/primary_green"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"/>

            <TextView
                android:id="@+id/btn_sem"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="SEM"
                android:gravity="center"
                android:textStyle="bold"
                android:textColor="@color/text_muted"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"/>

            <TextView
                android:id="@+id/btn_mes"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="MES"
                android:gravity="center"
                android:textStyle="bold"
                android:textColor="@color/text_muted"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"/>

            <TextView
                android:id="@+id/btn_anio"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="AÑO"
                android:gravity="center"
                android:textStyle="bold"
                android:textColor="@color/text_muted"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"/>
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@color/surface">

            <LinearLayout
                android:id="@+id/chartContainer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="[ Zona de Gráfica Global ]"
                    android:textColor="#BDBDBD"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/border_color"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Comparador de registro"
                        android:textSize="14sp"
                        android:textColor="@color/text_muted"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvResumenPeriodo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        tools:text="Total: 110L | $ 22000"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_main"
                        android:layout_marginBottom="16dp"/>

                    <Button
                        android:id="@+id/btnFiltroPersonalizado"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="COMPARAR FECHAS EXACTAS"
                        android:textColor="@color/primary_green"
                        app:strokeColor="@color/primary_green"
                        app:cornerRadius="8dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:id="@+id/capaBloqueoEstadisticas"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#F2FAFAFA"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="20dp"
                android:elevation="3dp">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@android:drawable/ic_secure"
                    android:layout_marginBottom="8dp"
                    app:tint="#757575"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Función Premium"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="@color/text_main"
                    android:layout_marginBottom="12dp"/>
            </LinearLayout>
        </FrameLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Exportación de Datos"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/text_main"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="12dp"/>

        <!-- Botones de Exportación (PDF, EXCEL, COMPARTIR) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnExportPdf"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="PDF"
                android:textColor="@color/surface"
                android:backgroundTint="@color/primary_green"
                app:icon="@android:drawable/ic_menu_save"
                app:iconTint="@color/surface"
                android:layout_marginEnd="4dp"
                app:cornerRadius="12dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnExportExcel"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="EXCEL"
                android:textColor="@color/surface"
                android:backgroundTint="@color/primary_green"
                app:icon="@android:drawable/ic_menu_agenda"
                app:iconTint="@color/surface"
                android:layout_marginHorizontal="4dp"
                app:cornerRadius="12dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnShare"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="SHARE"
                android:textColor="@color/surface"
                android:backgroundTint="@color/accent_purple"
                app:icon="@android:drawable/ic_menu_share"
                app:iconTint="@color/surface"
                android:layout_marginStart="4dp"
                app:cornerRadius="12dp"/>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Últimas Entregas"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/text_main"
            android:layout_marginBottom="12dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvUltimasEntregas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            tools:itemCount="3"
            tools:listitem="@layout/item_entrega" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>