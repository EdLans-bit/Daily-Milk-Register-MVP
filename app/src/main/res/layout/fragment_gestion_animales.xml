<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_general">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="20dp">

            <!-- CARD: PRODUCCION POR VACA INDIVIDUAL -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/primary_green"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Seleccionar Animal"
                        android:textColor="@color/text_muted"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvSeleccionVaca"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        tools:listitem="@layout/item_vaca_seleccion"
                        android:layout_marginBottom="16dp"/>

                    <TextView
                        android:id="@+id/tvNombreAnimalSeleccionado"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Producción por Vaca Individual"
                        android:textColor="@color/primary_green"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:id="@+id/tvResumenProduccionIndividual"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:lineSpacingExtra="4dp"
                        android:textColor="@color/text_main"
                        android:textSize="14sp"
                        tools:text="Vaca Mariposa: 14.2 Litros hoy\nPromedio Individual: 13.8 L/día\n\nVaca Lucera: 12.5 Litros hoy\nPromedio Individual: 12.9 L/día" />

                    <!-- Gráfica de Tendencia -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:layout_marginTop="16dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/border_color">

                        <com.github.mikephil.charting.charts.LineChart
                            android:id="@+id/chartTendenciaVaca"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="8dp"/>

                        <TextView
                            android:id="@+id/tvChartPlaceholder"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="[Gráfica Gratis de Tendencia por Vaca]"
                            android:textColor="@color/primary_green"
                            android:textStyle="italic"
                            android:visibility="gone"/>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- CARD: PREDICCIÓN POR VACA -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/primary_purple"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_badge_purple"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@android:drawable/ic_lock_idle_lock"
                            app:tint="@color/primary_purple"
                            android:contentDescription="Locked" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="PREDICCIÓN POR VACA"
                            android:textColor="@color/primary_purple"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Comportamiento Esperado (Siguiente Semana)"
                        android:textColor="@color/text_muted"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/tvPrediccionVacas"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/primary_purple"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:lineSpacingExtra="4dp"
                        tools:text="• Vaca Mariposa: Estable (+2%)\n• Vaca Lucera: Riesgo de baja (-5%)" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnBloquearPrediccion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bloquearla"
                        android:layout_gravity="end"
                        android:layout_marginTop="12dp"
                        app:backgroundTint="@color/primary_purple"
                        style="@style/Widget.Material3.Button.TonalButton"/>

                    <TextView
                        android:id="@+id/tvMensajePremium"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="(activar premium)"
                        android:textColor="@color/primary_purple"
                        android:textSize="12sp"
                        android:layout_gravity="end"
                        android:visibility="gone"
                        tools:visibility="visible"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
