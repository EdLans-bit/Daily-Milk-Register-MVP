<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_general">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header: Icon + Title -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_edit"
                app:tint="@color/primary_green"
                android:layout_marginEnd="12dp"
                android:contentDescription="@string/app_name" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nuevo_registro"
                android:textColor="@color/primary_green"
                android:textSize="28sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fecha de Ordeño / Venta"
            android:textColor="@color/text_main"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginBottom="8dp"/>

        <!-- Date Selector (Matches Image) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_fecha"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            tools:text="01 / 06 / 2026"
            android:textColor="@color/text_main"
            android:backgroundTint="@color/surface"
            app:strokeColor="@color/border_color"
            app:strokeWidth="1dp"
            app:cornerRadius="24dp"
            app:icon="@android:drawable/ic_menu_month"
            app:iconTint="@color/primary_green"
            app:iconGravity="textEnd"
            android:paddingHorizontal="24dp"
            android:textAllCaps="false"
            android:layout_marginBottom="16dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

        <!-- Quantity Input (Matches Image) -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Cantidad (Litros)"
            app:boxCornerRadiusTopStart="24dp"
            app:boxCornerRadiusTopEnd="24dp"
            app:boxCornerRadiusBottomStart="24dp"
            app:boxCornerRadiusBottomEnd="24dp"
            app:boxStrokeColor="@color/border_color"
            android:layout_marginBottom="16dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_cantidad"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:padding="20dp"
                android:textColor="@color/text_main"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Animal Selection (Matches Image) -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Vaca o Lote"
            app:boxCornerRadiusTopStart="24dp"
            app:boxCornerRadiusTopEnd="24dp"
            app:boxCornerRadiusBottomStart="24dp"
            app:boxCornerRadiusBottomEnd="24dp"
            app:boxStrokeColor="@color/border_color"
            android:layout_marginBottom="16dp">

            <AutoCompleteTextView
                android:id="@+id/et_animal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:padding="20dp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Comprador Selection (Maintained as requested) -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Comprador / Destino"
            app:boxCornerRadiusTopStart="24dp"
            app:boxCornerRadiusTopEnd="24dp"
            app:boxCornerRadiusBottomStart="24dp"
            app:boxCornerRadiusBottomEnd="24dp"
            app:boxStrokeColor="@color/border_color"
            android:layout_marginBottom="24dp">

            <AutoCompleteTextView
                android:id="@+id/et_comprador"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:padding="20dp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Purple Save Button (Matches Image) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_guardar"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:text="@string/guardar_registro_manual"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="24dp"
            android:backgroundTint="#6200EE"
            android:textColor="@android:color/white"
            app:icon="@android:drawable/ic_menu_save"
            app:iconGravity="textStart"
            android:layout_marginBottom="24dp"/>

        <!-- Voice Card (Matches Image) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="140dp"
            app:cardCornerRadius="32dp"
            app:cardBackgroundColor="@color/surface"
            app:strokeWidth="1.5dp"
            app:strokeColor="#C8D4D0"
            app:cardElevation="0dp"
            android:layout_marginBottom="120dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageButton
                    android:id="@+id/btn_mic_giant"
                    android:layout_width="86dp"
                    android:layout_height="86dp"
                    android:background="@drawable/circle_bg_primary"
                    android:backgroundTint="@color/primary_green"
                    android:src="@android:drawable/ic_btn_speak_now"
                    app:tint="@android:color/white"
                    android:layout_gravity="center"
                    android:contentDescription="@string/dictar_voz"
                    android:scaleType="centerInside"
                    android:padding="16dp"/>
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
