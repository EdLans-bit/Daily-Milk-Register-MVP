<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_general"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nuevo Registro"
            android:textColor="@color/primary"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="28dp"
            app:drawableStartCompat="@android:drawable/ic_menu_edit"
            android:drawablePadding="10dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fecha de Ordeño / Venta"
            android:textColor="@color/text_main"
            android:textStyle="bold"
            android:layout_marginBottom="10dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_fecha"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:text="26 / 05 / 2026"
            android:textColor="@color/text_main"
            android:backgroundTint="@color/surface"
            app:strokeColor="@color/border"
            app:strokeWidth="1.5dp"
            app:cornerRadius="16dp"
            app:icon="@android:drawable/ic_menu_month"
            app:iconTint="@color/primary"
            app:iconGravity="textEnd"
            android:layout_marginBottom="24dp"/>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Cantidad (Litros)"
            app:boxCornerRadiusTopStart="16dp"
            app:boxCornerRadiusTopEnd="16dp"
            app:boxCornerRadiusBottomStart="16dp"
            app:boxCornerRadiusBottomEnd="16dp"
            android:layout_marginBottom="24dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_cantidad"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:padding="20dp"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Comprador / Destino"
            app:boxCornerRadiusTopStart="16dp"
            app:boxCornerRadiusTopEnd="16dp"
            app:boxCornerRadiusBottomStart="16dp"
            app:boxCornerRadiusBottomEnd="16dp"
            android:layout_marginBottom="16dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_comprador"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPersonName"
                android:padding="20dp"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_guardar"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Guardar Registro Manual"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="16dp"
            android:layout_marginBottom="24dp"
            app:icon="@android:drawable/ic_menu_save"
            app:iconGravity="textStart"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            app:cardBackgroundColor="@color/surface"
            app:strokeColor="@color/accent"
            app:strokeWidth="2dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="80dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="36dp">

                <ImageButton
                    android:id="@+id/btn_mic_giant"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:background="@drawable/circle_bg_primary"
                    android:src="@android:drawable/ic_btn_speak_now"
                    app:tint="@color/surface"
                    android:elevation="8dp"
                    android:layout_marginBottom="20dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Comando de voz rápido\nMantén presionado para dictar los datos rápidamente."
                    android:textAlignment="center"
                    android:textColor="@color/text_muted"
                    android:textSize="14sp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>