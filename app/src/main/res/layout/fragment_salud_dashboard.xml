<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_general"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- TÍTULO DE LA PANTALLA -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Dashboard de Salud"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/primary_green"
            android:layout_marginBottom="24dp"/>

        <!-- SECCIÓN: PREDICCIÓN GLOBAL -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/prediccion_produccion"
            android:textColor="@color/text_main"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardPrediccionGlobal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="16dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_border_left_green"
                android:orientation="vertical"
                android:padding="20dp"
                android:paddingStart="24dp"
                tools:ignore="RtlSymmetry">

                <TextView
                    android:id="@+id/tvLabelPrediccionGlobal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/mañana_ema"
                    android:textColor="@color/text_muted"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvAmountPrediccionGlobal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    tools:text="245 Litros"
                    android:textColor="@color/text_main"
                    android:textSize="24sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- SECCIÓN: TOP 3 RANKING DE PRODUCCIÓN -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Top 3 Producción (Total)"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_main"
            android:layout_marginBottom="12dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvTopRanking"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="100dp"
            android:nestedScrollingEnabled="false"
            tools:listitem="@layout/item_vaca_ranking_crud" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
