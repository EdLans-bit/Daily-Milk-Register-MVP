<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="12dp"
    app:strokeColor="@color/border"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/imgComprador"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_myplaces"
            app:tint="@color/primary"
            android:contentDescription="Icono comprador"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_weight="1"
            android:layout_marginStart="16dp">

            <TextView
                android:id="@+id/tvNombreComprador"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nombre Comprador"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_main"/>

            <TextView
                android:id="@+id/tvPrecioYTelefono"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$ 0.00 | 00000000"
                android:textSize="12sp"
                android:textColor="@color/text_muted"/>
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnBorrarComprador"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_delete"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/btn_danger_text"
            android:contentDescription="Borrar comprador"/>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
